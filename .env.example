# JEC Project - Docker Deployment Configuration
# Copy this file to .env and adjust values as needed.

# Domain served by Cloudflare → Traefik
DOMAIN=jec.dataplay.ir

# GHCR images built by GitHub Actions (hamedf62/JEC repo)
IMAGE_BACKEND=ghcr.io/hamedf62/jec/backend:latest
IMAGE_FRONTEND=ghcr.io/hamedf62/jec/frontend:latest

# Compose project name (affects container/network naming)
COMPOSE_PROJECT_NAME=jec
